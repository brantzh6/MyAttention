# MyAttention API Configuration

# Database
DATABASE_URL=postgresql+asyncpg://myattention:myattention@localhost:5432/myattention
REDIS_URL=redis://localhost:6379
QDRANT_URL=http://localhost:6333

# Alibaba Cloud Bailian API (Required)
# Get your API key from: https://bailian.console.aliyun.com/
QWEN_API_KEY=your_dashscope_api_key_here

# Optional: Other LLM providers (for multi-provider voting)
# ANTHROPIC_API_KEY=your_anthropic_api_key
# OPENAI_API_KEY=your_openai_api_key

# Optional: Local Ollama
OLLAMA_BASE_URL=http://localhost:11434

# ============== Notifications ==============

# --- Feishu (飞书) ---
# 两种配置方式，选择其中一种：

# 方式1: 应用 API 模式（推荐，功能完整）
# 获取方式: 飞书开发者后台 → 创建企业自建应用 → 获取 App ID 和 App Secret
# 权限: 需要开启 im:message, im:chat 等权限
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 推送目标: 群聊 oc_xxx 或用户 ou_xxx
FEISHU_DEFAULT_TARGET_ID=oc_xxxxxxxxxxxxxxxxxxxxx

# 方式2: Webhook 模式（简单，仅支持单向推送）
# 获取方式: 群设置 → 群机器人 → 添加机器人 → 自定义
# FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxx

# --- DingTalk (钉钉) ---
# Webhook 模式
# 获取方式: 群设置 → 智能群助手 → 添加机器人 → 自定义
DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=xxx
# 签名密钥（推荐使用加签方式，提高安全性）
DINGTALK_SECRET=SECxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# App settings
DEBUG=true