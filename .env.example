# MyAttention Environment Configuration
# Copy this file to .env and fill in your API keys

# Database (auto-configured by docker-compose)
DATABASE_URL=postgresql+asyncpg://myattention:myattention@localhost:5432/myattention
REDIS_URL=redis://localhost:6379
QDRANT_URL=http://localhost:6333

# LLM API Keys (fill in as needed)
# Priority: Qwen > GLM > Minimax > Kimi > Claude > OpenAI

# Qwen (通义千问) - Recommended for Chinese
QWEN_API_KEY=

# GLM (智谱) - Cost effective
GLM_API_KEY=

# Kimi (Moonshot) - Long context
KIMI_API_KEY=

# Anthropic Claude - Strong reasoning
ANTHROPIC_API_KEY=

# OpenAI GPT-4 - General purpose
OPENAI_API_KEY=

# Ollama (Local) - Privacy first
OLLAMA_BASE_URL=http://localhost:11434

# Notification Webhooks
FEISHU_WEBHOOK_URL=
DINGTALK_WEBHOOK_URL=

# App Settings
DEBUG=true
