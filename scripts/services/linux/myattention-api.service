[Unit]
Description=IKE API
After=network.target postgresql.service redis.service
Wants=postgresql.service redis.service

[Service]
Type=simple
WorkingDirectory=/opt/ike/services/api
Environment=PYTHONUTF8=1
EnvironmentFile=/opt/ike/services/api/.env
ExecStart=/opt/ike/.venv/bin/python -m uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5
StandardOutput=append:/var/log/ike/api.log
StandardError=append:/var/log/ike/api.log

[Install]
WantedBy=multi-user.target
