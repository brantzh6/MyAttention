<service>
  <id>IKEWeb</id>
  <name>IKEWeb</name>
  <description>IKE Web service</description>
  <executable>C:\Program Files\nodejs\node.exe</executable>
  <arguments>D:\code\IKE\services\web\.next\standalone\server.js</arguments>
  <workingdirectory>D:\code\IKE\services\web</workingdirectory>
  <stoptimeout>15sec</stoptimeout>
  <startmode>Manual</startmode>
  <logpath>D:\code\IKE\.runtime\logs</logpath>
  <log mode="roll-by-size-time">
    <sizeThreshold>10240</sizeThreshold>
    <pattern>yyyyMMdd</pattern>
    <autoRollAtTime>00:00:00</autoRollAtTime>
    <zipOlderThanNumDays>7</zipOlderThanNumDays>
  </log>
  <env name="PORT" value="3000" />
  <env name="HOSTNAME" value="127.0.0.1" />
  <env name="API_URL" value="http://127.0.0.1:8000" />
  <env name="NEXT_PUBLIC_API_URL" value="http://127.0.0.1:8000" />
</service>
